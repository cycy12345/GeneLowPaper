\name{Fig2D_TCGA_Clin}
\alias{Fig2D_TCGA_Clin}
\title{TCGA Gene Expression and Clinical Correlation Analysis
}
\description{
Analyzes the association between target gene expression and clinical features

(Gender, Age, T_stage, M_stage, N_stage, Stage) in TCGA data. Performs

univariate and multivariate Cox regression and generates forest plots.

If the gene is significant in multivariate Cox, a nomogram is also drawn.


Default is \code{"mRNA"}.

Default is \code{"F:/BioMed/预分析/data/TCGA"}.
}
\usage{
Fig2D_TCGA_Clin(TCGA_pro = "LUAD", gene, gene_type = "mRNA", outdir = "./", plotWidth = 8, plotHeight = 6, coxWidth = 8, coxHeight = 6, data_dir = "F:/BioMed/预分析/data/TCGA", color_dis = color_dis_default)
}
\arguments{
  \item{TCGA_pro}{Character. TCGA project abbreviation, e.g. \code{"LUAD"}.}
  \item{gene}{Character. Target gene symbol.}
  \item{gene_type}{Character. Gene type: \code{"mRNA"}, \code{"lncrna"}, or \code{"mirna"}.}
  \item{outdir}{Character. Output directory. Default is \code{"./"}.}
  \item{plotWidth}{Numeric. Clinical plot width. Default is 8.}
  \item{plotHeight}{Numeric. Clinical plot height. Default is 6.}
  \item{coxWidth}{Numeric. Cox forest plot width. Default is 8.}
  \item{coxHeight}{Numeric. Cox forest plot height. Default is 6.}
  \item{data_dir}{Character. Root directory of TCGA data.}
  \item{color_dis}{Character vector. Color palette. Defaults to \code{color_dis_default}.}
}
\details{
Output files are saved under \code{outdir/2_Fig/Fig2D_clin/} and include:

alluvial plots for each clinical feature, univariate and multivariate Cox

CSV results and forest plots, and a nomogram (if applicable).


}
\value{
Invisibly returns the multivariate Cox result data frame.
}
\examples{
\dontrun{

Fig2D_TCGA_Clin(TCGA_pro = "LUAD", gene = "IL36RN", gene_type = "mRNA")

}

}
